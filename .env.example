# ── Provider selection ────────────────────────────────────────────────────────
# Choose one: groq | gemini
LLM_PROVIDER=gemini

# ── API keys (only the one matching LLM_PROVIDER is required) ─────────────────
GOOGLE_API_KEY=
GROQ_API_KEY=

# ── Model overrides (optional — defaults are set in config.py) ────────────────
GEMINI_MODEL=gemini-1.5-flash
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=4096

# ── Dataset path override (optional — falls back to data/NY-House-Dataset.csv) ─
DATASET_PATH=

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=llm-data-science-assistant
